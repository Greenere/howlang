# ─────────────────────────────────────────────────────────────────────────────
# how_eval.how  —  Tree-walking evaluator for the Howlang meta-interpreter
#
# Environments are linked maps:  { "vars": map(), "parent": env_or_none }
# Runtime values are plain Howlang values — numbers, strings, bools, none,
# plus HowList/HowMap from the host.  Functions are maps:
#   { "tag": "closure", "params": list, "branches": list, "env": env, "is_loop": bool }
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment ───────────────────────────────────────────────────────────────

var env_new = (parent){
    :: {"vars": map(), "parent": parent}
}

var env_get = (env, name){
    has_key(env("vars"), name): { :: get_key(env("vars"), name) },
    env("parent") != none:       { :: env_get(env("parent"), name) },
    :: none     # undefined → none (lenient)
}

var env_set = (env, name, val){
    set_key(env("vars"), name, val)
}

var env_assign = (env, name, val){
    has_key(env("vars"), name): {
        set_key(env("vars"), name, val)
    },
    has_key(env("vars"), name) == false and env("parent") != none: {
        env_assign(env("parent"), name, val)
    },
    has_key(env("vars"), name) == false and env("parent") == none: {
        set_key(env("vars"), name, val)   # declare at top level as fallback
    }
}

# ── Truthiness ────────────────────────────────────────────────────────────────

var is_truthy = (v){
    v == none  :: false,
    v == false :: false,
    v == 0     :: false,
    :: true
}

# ── Exceptions via result tags ────────────────────────────────────────────────
# We can't throw real exceptions in meta-Howlang, so we thread a signal map
# through evaluation:
#   normal:  {"sig": "ok",     "val": value}
#   return:  {"sig": "return", "val": value}
#   break:   {"sig": "break",  "val": none}

var ok_sig     = (v)    { :: {"sig": "ok",     "val": v}    }
var ret_sig    = (v)    { :: {"sig": "return",  "val": v}    }
var break_sig  = ()     { :: {"sig": "break",   "val": none} }

# ── Forward declarations ──────────────────────────────────────────────────────
var eval_node     = none
var eval_branches = none
var eval_block    = none
var call_fn       = none

# ── Value display ─────────────────────────────────────────────────────────────
var meta_repr = (v){
    v == none  :: "none",
    v == true  :: "true",
    v == false :: "false",
    type(v) == "number": {
        v == floor(v) :: str(floor(v)),
        :: str(v)
    },
    :: str(v)
}

# ── Built-in functions available inside the meta-interpreter ──────────────────
var make_globals = (){
    var g = env_new(none),

    env_set(g, "print", {"tag": "builtin", "name": "print"}),
    env_set(g, "len",   {"tag": "builtin", "name": "len"}),
    env_set(g, "str",   {"tag": "builtin", "name": "str"}),
    env_set(g, "num",   {"tag": "builtin", "name": "num"}),
    env_set(g, "type",  {"tag": "builtin", "name": "type"}),
    env_set(g, "floor", {"tag": "builtin", "name": "floor"}),
    env_set(g, "push",  {"tag": "builtin", "name": "push"}),
    env_set(g, "pop",   {"tag": "builtin", "name": "pop"}),
    env_set(g, "list",  {"tag": "builtin", "name": "list"}),
    env_set(g, "map",   {"tag": "builtin", "name": "map"}),
    env_set(g, "keys",  {"tag": "builtin", "name": "keys"}),
    env_set(g, "has_key",  {"tag": "builtin", "name": "has_key"}),
    env_set(g, "ask",      {"tag": "builtin", "name": "ask"}),
    env_set(g, "args",     {"tag": "builtin", "name": "args"}),
    env_set(g, "dirof",    {"tag": "builtin", "name": "dirof"}),
    env_set(g, "_resolve_how",        {"tag": "builtin", "name": "_resolve_how"}),
    env_set(g, "_push_import_dir", {"tag": "builtin", "name": "_push_import_dir"}),
    # __dir is injected by how_meta.how after loading
    env_set(g, "_lex",     {"tag": "builtin", "name": "_meta_lex"}),
    env_set(g, "_host_call",  {"tag": "builtin", "name": "_host_call"}),
    env_set(g, "_meta_lex",   {"tag": "builtin", "name": "_meta_lex"}),
    env_set(g, "_meta_parse", {"tag": "builtin", "name": "_meta_parse"}),
    env_set(g, "_parse",   {"tag": "builtin", "name": "_meta_parse"}),
    env_set(g, "read",     {"tag": "builtin", "name": "read"}),
    env_set(g, "set_key",  {"tag": "builtin", "name": "set_key"}),
    env_set(g, "get_key",  {"tag": "builtin", "name": "get_key"}),
    env_set(g, "true",  true),
    env_set(g, "false", false),
    env_set(g, "none",  none),
    :: g
}

var call_builtin = (name, bargs){
    name == "print": {
        var i = 0, var parts = list(),
        (0:len(bargs)) = i{ push(parts, meta_repr(bargs(i))) },
        var s = "",
        (0:len(parts)) = i{
            i > 0: s = s + " ",
            s = s + parts(i)
        },
        print(s),
        :: ok_sig(none)
    },
    name == "len":     { :: ok_sig(len(bargs(0))) },
    name == "str":     { :: ok_sig(meta_repr(bargs(0))) },
    name == "num":     { :: ok_sig(num(str(bargs(0)))) },
    name == "type":    { :: ok_sig(type(bargs(0))) },
    name == "floor":   { :: ok_sig(floor(bargs(0))) },
    name == "push":    { push(bargs(0), bargs(1)), :: ok_sig(bargs(0)) },
    name == "pop":     { :: ok_sig(pop(bargs(0))) },
    name == "list":    { :: ok_sig(list()) },
    name == "map":     { :: ok_sig(map()) },
    name == "keys":    { :: ok_sig(keys(bargs(0))) },
    name == "has_key": { :: ok_sig(has_key(bargs(0), bargs(1))) },
    name == "set_key": { set_key(bargs(0), bargs(1), bargs(2)), :: ok_sig(bargs(2)) },
    name == "get_key": { :: ok_sig(get_key(bargs(0), bargs(1))) },
    name == "ask":     { :: ok_sig(ask(bargs(0))) },
    name == "args":   { :: ok_sig(args()) },
    name == "dirof":         { :: ok_sig(dirof(bargs(0))) },
    name == "_resolve_how":        { :: ok_sig(_resolve_how(bargs(0))) },
    name == "_push_import_dir": { :: ok_sig(_push_import_dir(bargs(0))) },
    name == "__get_meta_dir": { :: ok_sig(__get_meta_dir()) },
    name == "_lex":    { :: ok_sig(_lex(bargs(0))) },
    name == "_host_call":  { :: ok_sig(_host_call(bargs(0), bargs(1))) },
    name == "_meta_lex":   { :: ok_sig(_meta_lex(bargs(0))) },
    name == "_meta_parse": { :: ok_sig(_meta_parse(bargs(0))) },
    name == "_parse":  { :: ok_sig(_parse(bargs(0))) },
    name == "read":    { :: ok_sig(read(bargs(0))) },
    :: ok_sig(none)
}

# ── Augmented assignment helpers ──────────────────────────────────────────────
var apply_aug = (old, op, val){
    op == "+=" :: old + val,
    op == "-=" :: old - val,
    op == "*=" :: old * val,
    op == "/=" :: old / val,
    :: val
}

# ── Main evaluator ────────────────────────────────────────────────────────────
eval_node = (node, env){
    var tag = node("tag"),

    tag == "num"      :: ok_sig(node("v")),
    tag == "str"      :: ok_sig(node("v")),
    tag == "bool"     :: ok_sig(node("v")),
    tag == "none_lit" :: ok_sig(none),
    tag == "break_node" :: break_sig(),

    tag == "ident": {
        :: ok_sig(env_get(env, node("name")))
    },

    tag == "unary": {
        var r = eval_node(node("e"), env),
        r("sig") != "ok" :: r,
        node("op") == "-"   :: ok_sig(-r("val")),
        node("op") == "not" :: ok_sig(is_truthy(r("val")) == false),
        :: ok_sig(r("val"))
    },

    tag == "binop": {
        var op = node("op"),
        # Short-circuit
        op == "and": {
            var l = eval_node(node("l"), env),
            l("sig") != "ok" :: l,
            is_truthy(l("val")) == false :: ok_sig(l("val")),
            :: eval_node(node("r"), env)
        },
        op == "or": {
            var l = eval_node(node("l"), env),
            l("sig") != "ok" :: l,
            is_truthy(l("val")) :: ok_sig(l("val")),
            :: eval_node(node("r"), env)
        },
        var l = eval_node(node("l"), env),
        l("sig") != "ok" :: l,
        var r = eval_node(node("r"), env),
        r("sig") != "ok" :: r,
        var lv = l("val"), var rv = r("val"),
        op == "+"  :: ok_sig(lv + rv),
        op == "-"  :: ok_sig(lv - rv),
        op == "*"  :: ok_sig(lv * rv),
        op == "/"  :: ok_sig(lv / rv),
        op == "%"  :: ok_sig(lv % rv),
        op == "==" :: ok_sig(lv == rv),
        op == "!=" :: ok_sig(lv != rv),
        op == "<"  :: ok_sig(lv < rv),
        op == ">"  :: ok_sig(lv > rv),
        op == "<=" :: ok_sig(lv <= rv),
        op == ">=" :: ok_sig(lv >= rv),
        :: ok_sig(none)
    },

    tag == "assign": {
        var rv = eval_node(node("val"), env),
        rv("sig") != "ok" :: rv,
        var tgt = node("target"),
        tgt("tag") == "ident": {
            var op = node("op"),
            op == "=": {
                env_assign(env, tgt("name"), rv("val")),
                :: ok_sig(rv("val"))
            },
            var old = env_get(env, tgt("name")),
            var newv = apply_aug(old, op, rv("val")),
            env_assign(env, tgt("name"), newv),
            :: ok_sig(newv)
        },
        tgt("tag") == "dot": {
            var objr = eval_node(tgt("obj"), env),
            objr("sig") != "ok" :: objr,
            set_key(objr("val"), tgt("attr"), rv("val")),
            :: ok_sig(rv("val"))
        },
        :: ok_sig(none)
    },

    tag == "dot": {
        var r = eval_node(node("obj"), env),
        r("sig") != "ok" :: r,
        var obj  = r("val"),
        var attr = node("attr"),
        type(obj) == "map" or type(obj) == "instance": {
            has_key(obj, attr) :: ok_sig(get_key(obj, attr)),
            :: ok_sig(none)
        },
        :: ok_sig(none)
    },

    tag == "slice": {
        var r = eval_node(node("col"), env),
        r("sig") != "ok" :: r,
        var col = r("val"),
        var start = none, var stop = none,
        node("start") != none: {
            var rs = eval_node(node("start"), env),
            rs("sig") != "ok" :: rs,
            start = rs("val")
        },
        node("stop") != none: {
            var re = eval_node(node("stop"), env),
            re("sig") != "ok" :: re,
            stop = re("val")
        },
        type(col) == "list": {
            var s = 0,
            start != none: s = floor(start),
            var e = len(col),
            stop != none: e = floor(stop),
            :: ok_sig(col(s:e))
        },
        type(col) == "string": {
            var s = 0,
            start != none: s = floor(start),
            var e = len(col),
            stop != none: e = floor(stop),
            :: ok_sig(col(s:e))
        },
        :: ok_sig(none)
    },

    tag == "call": {
        var rc = eval_node(node("callee"), env),
        rc("sig") != "ok" :: rc,
        var callee = rc("val"),
        # Evaluate args
        var args = list(),
        var ai = 0,
        var arg_nodes = node("args"),
        var arg_ok = true,
        (0:len(arg_nodes)) = ai{
            var ra = eval_node(arg_nodes(ai), env),
            ra("sig") != "ok": { arg_ok = false },
            ra("sig") == "ok": push(args, ra("val"))
        },
        # Call
        type(callee) == "map" and has_key(callee, "tag") and get_key(callee, "tag") == "builtin": {
            :: call_builtin(get_key(callee, "name"), args)
        },
        type(callee) == "map" and has_key(callee, "tag") and get_key(callee, "tag") == "closure": {
            :: call_fn(callee, args)
        },
        # Call on list/map → index
        type(callee) == "list": { :: ok_sig(callee(floor(args(0)))) },
        type(callee) == "map":  {
            has_key(callee, args(0)): { :: ok_sig(get_key(callee, args(0))) },
            :: ok_sig(none)
        },
        # HOST function (HowFunction object) — call via host dispatch
        type(callee) == "function": {
            :: ok_sig(_host_call(callee, args))
        },
        :: ok_sig(none)
    },

    tag == "func": {
        :: ok_sig({"tag": "closure", "params": node("params"),
                   "branches": node("branches"), "env": env,
                   "is_loop": node("is_loop")})
    },

    tag == "map_lit": {
        var items = node("items"),
        # Detect list vs map
        len(items) == 0: { :: ok_sig(map()) },
        items(0)("k") == none: {
            var lst = list(),
            var ii = 0,
            (0:len(items)) = ii{
                var rv2 = eval_node(items(ii)("v"), env),
                rv2("sig") == "ok": push(lst, rv2("val"))
            },
            :: ok_sig(lst)
        },
        var m = map(),
        var ii = 0,
        (0:len(items)) = ii{
            var rk2 = eval_node(items(ii)("k"), env),
            var rv2 = eval_node(items(ii)("v"), env),
            rk2("sig") == "ok" and rv2("sig") == "ok": {
                set_key(m, rk2("val"), rv2("val"))
            }
        },
        :: ok_sig(m)
    },

    tag == "how_stmt": {
        var mod_name = node("name"),
        var mod_path = _resolve_how(mod_name),
        var mod_src  = read(mod_path),
        # Resolve _lex and _parse from env so meta versions can override builtins
        var lex_fn   = env_get(env, "_lex"),
        var parse_fn = env_get(env, "_parse"),
        # Call them: call_fn handles both closures and builtins
        var lex_args   = list(),
        push(lex_args, mod_src),
        var r_lex      = call_fn(lex_fn, lex_args),
        r_lex("sig") != "ok" :: r_lex,
        var mod_tokens = r_lex("val"),
        var parse_args = list(),
        push(parse_args, mod_tokens),
        var r_parse    = call_fn(parse_fn, parse_args),
        r_parse("sig") != "ok" :: r_parse,
        var mod_ast    = r_parse("val"),
        # Run the module in a fresh env that also has _lex/_parse overrides
        var mod_g    = make_globals(),
        set_key(mod_g("vars"), "_lex",   lex_fn),
        set_key(mod_g("vars"), "_parse", parse_fn),
        var mod_env  = env_new(mod_g),
        eval_node(mod_ast, mod_env),
        # Expose all module vars as a map
        var mod_map  = map(),
        var mod_keys = keys(mod_env("vars")),
        var ki = 0,
        (0:len(mod_keys)) = ki{
            set_key(mod_map, mod_keys(ki), get_key(mod_env("vars"), mod_keys(ki)))
        },
        env_set(env, mod_name, mod_map),
        :: ok_sig(mod_map)
    },
    tag == "var_decl": {
        var r = eval_node(node("val"), env),
        r("sig") != "ok" :: r,
        env_set(env, node("name"), r("val")),
        :: ok_sig(r("val"))
    },

    tag == "block": {
        :: eval_block(node("stmts"), env)
    },

    tag == "for_loop": {
        var start_r  = none,
        node("start") != none: start_r = eval_node(node("start"), env),
        var start_v  = 0,
        start_r != none and start_r("sig") == "ok": start_v = floor(start_r("val")),
        var stop_r   = eval_node(node("stop"), env),
        stop_r("sig") != "ok" :: stop_r,
        var stop_v   = floor(stop_r("val")),
        var iter_var = node("var"),
        var branches = node("branches"),
        var loop_i   = start_v,
        var loop_res = ok_sig(none),
        var for_done = false,
        (:)={
            for_done: break,
            loop_i >= stop_v: { for_done = true },
            loop_i < stop_v: {
                env_set(env, iter_var, loop_i),
                var bi = 0,
                var iter_done = false,
                (:)={
                    iter_done: break,
                    bi >= len(branches): { iter_done = true },
                    bi < len(branches): {
                        var b = branches(bi),
                        b("tag") == "var_decl": {
                            var r = eval_node(b("val"), env),
                            r("sig") == "ok": env_set(env, b("name"), r("val")),
                            bi = bi + 1
                        },
                        b("tag") == "branch": {
                            var cond = b("cond"),
                            var cond_ok = true,
                            cond != none: {
                                var rc = eval_node(cond, env),
                                rc("sig") != "ok": { loop_res = rc, for_done = true, iter_done = true, cond_ok = false },
                                rc("sig") == "ok" and is_truthy(rc("val")) == false: { cond_ok = false }
                            },
                            cond_ok and b("is_ret") == false: {
                                var rb = eval_node(b("body"), env),
                                rb("sig") == "break": { for_done = true, iter_done = true },
                                rb("sig") == "return": { loop_res = rb, for_done = true, iter_done = true },
                                rb("sig") == "ok": bi = bi + 1
                            },
                            cond_ok and b("is_ret"): {
                                # :: branch runs once after all iterations (post-loop return)
                                # Don't evaluate here — save for after loop
                                bi = bi + 1
                            },
                            cond_ok == false: { bi = bi + 1 }
                        },
                        b("tag") != "var_decl" and b("tag") != "branch": { bi = bi + 1 }
                    }
                },
                for_done == false: loop_i = loop_i + 1
            }
        },
        # Run post-loop :: branches
        loop_res("sig") == "ok": {
            var bi2 = 0,
            (:)={
                bi2 >= len(branches): break,
                var b = branches(bi2),
                b("tag") == "branch" and b("is_ret"): {
                    var cond2 = b("cond"),
                    var cond2_ok = true,
                    cond2 != none: {
                        var rc2 = eval_node(cond2, env),
                        rc2("sig") != "ok": { loop_res = rc2, bi2 = len(branches), cond2_ok = false },
                        rc2("sig") == "ok" and is_truthy(rc2("val")) == false: { cond2_ok = false }
                    },
                    cond2_ok: {
                        var rb2 = eval_node(b("body"), env),
                        loop_res = ok_sig(rb2("val")),
                        bi2 = len(branches)
                    },
                    cond2_ok == false: { bi2 = bi2 + 1 }
                },
                b("tag") != "branch" or b("is_ret") == false: { bi2 = bi2 + 1 }
            }
        },
        :: loop_res
    },

    tag == "prog": {
        var stmts = node("stmts"),
        var si = 0,
        var result = ok_sig(none),
        (0:len(stmts)) = si{
            var r = eval_node(stmts(si), env),
            r("sig") == "return" or r("sig") == "break": { result = r, si = len(stmts) },
            r("sig") == "ok": result = r
        },
        :: result
    },

    :: ok_sig(none)
}

# ── Block evaluation ──────────────────────────────────────────────────────────
eval_block = (stmts, env){
    var child = env_new(env),
    var si = 0,
    var result = ok_sig(none),
    (0:len(stmts)) = si{
        result("sig") == "ok": {
            var r = eval_node(stmts(si), child),
            result = r
        }
    },
    :: result
}

# ── Branch list evaluation ────────────────────────────────────────────────────
eval_branches = (branches, env){
    var bi = 0,
    var result = ok_sig(none),
    var done = false,
    (:)={
        done: break,
        bi >= len(branches): { done = true },
        bi < len(branches): {
            var b   = branches(bi),
            var tag = b("tag"),

            # var_decl inside branch list
            tag == "var_decl": {
                var r = eval_node(b("val"), env),
                r("sig") == "ok": env_set(env, b("name"), r("val")),
                bi = bi + 1
            },

            # branch node
            tag == "branch": {
                var cond = b("cond"),
                var cond_ok = true,
                cond != none: {
                    var rc = eval_node(cond, env),
                    rc("sig") != "ok": { result = rc, done = true, cond_ok = false },
                    rc("sig") == "ok" and is_truthy(rc("val")) == false: { cond_ok = false }
                },
                cond_ok: {
                    b("is_ret"): {
                        var rb = eval_node(b("body"), env),
                        rb("sig") == "break": { result = break_sig(), done = true },
                        rb("sig") != "break": {
                            result = ret_sig(rb("val")),
                            done   = true
                        }
                    },
                    b("is_ret") == false: {
                        var rb = eval_node(b("body"), env),
                        rb("sig") == "break": { result = break_sig(), done = true },
                        rb("sig") == "return": { result = rb, done = true },
                        rb("sig") == "ok": bi = bi + 1
                    }
                },
                cond_ok == false: { bi = bi + 1 }
            },

            tag != "var_decl" and tag != "branch": { bi = bi + 1 }
        }
    },
    :: result
}

# ── Function call ─────────────────────────────────────────────────────────────
call_fn = (fn, args){
    # Dispatch builtins (e.g. {tag:"builtin", name:"_lex"})
    type(fn) == "map" and has_key(fn, "tag") and fn("tag") == "builtin": {
        :: call_builtin(fn("name"), args)
    },
    fn("is_loop"): {
        # Unbounded loop
        var local = env_new(fn("env")),
        var loop_result = ok_sig(none),
        var loop_done   = false,
        (:)={
            loop_done: break,
            var r = eval_branches(fn("branches"), local),
            r("sig") == "return": { loop_result = ok_sig(r("val")), loop_done = true },
            r("sig") == "break":  { loop_result = ok_sig(none),     loop_done = true },
            r("sig") == "ok":     none   # keep looping
        },
        :: loop_result
    },
    # Normal function
    var local = env_new(fn("env")),
    var pi = 0,
    (0:len(fn("params"))) = pi{
        env_set(local, fn("params")(pi), args(pi))
    },
    var r = eval_branches(fn("branches"), local),
    r("sig") == "return" :: ok_sig(r("val")),
    :: ok_sig(none)
}

# ── Public entry point ────────────────────────────────────────────────────────
var meta_eval = (ast){
    var g = make_globals(),
    :: eval_node(ast, g)
}
