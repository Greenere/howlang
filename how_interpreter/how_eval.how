# ─────────────────────────────────────────────────────────────────────────────
# how_eval.how  —  Tree-walking evaluator for the Howlang meta-interpreter
#
# Environments are linked maps:  { "vars": map(), "parent": env_or_none }
# Runtime values are plain Howlang values — numbers, strings, bools, none,
# plus HowList/HowMap from the host.  Functions are maps:
#   { "tag": "closure", "params": list, "branches": list, "env": env, "is_loop": bool }
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment ───────────────────────────────────────────────────────────────

var env_new = (parent){
    :: {"vars": map(), "parent": parent}
}

var env_get = (env, name){
    has_key(env("vars"), name): { :: get_key(env("vars"), name) },
    env("parent") != none:       { :: env_get(env("parent"), name) },
    :: none     # undefined → none (lenient)
}

var env_set = (env, name, val){
    set_key(env("vars"), name, val)
}

var env_assign = (env, name, val){
    has_key(env("vars"), name): {
        set_key(env("vars"), name, val)
    },
    has_key(env("vars"), name) == false and env("parent") != none: {
        env_assign(env("parent"), name, val)
    },
    has_key(env("vars"), name) == false and env("parent") == none: {
        set_key(env("vars"), name, val)   # declare at top level as fallback
    }
}

# ── Truthiness ────────────────────────────────────────────────────────────────

var is_truthy = (v){
    v == none  :: false,
    v == false :: false,
    v == 0     :: false,
    :: true
}

# ── Exceptions via result tags ────────────────────────────────────────────────
# We can't throw real exceptions in meta-Howlang, so we thread a signal map
# through evaluation:
#   normal:  {"sig": "ok",     "val": value}
#   return:  {"sig": "return", "val": value}
#   break:   {"sig": "break",  "val": none}

var ok_sig     = (v)    { :: {"sig": "ok",     "val": v}    }
var ret_sig    = (v)    { :: {"sig": "return",  "val": v}    }
var break_sig  = ()     { :: {"sig": "break",   "val": none} }

# ── Forward declarations ──────────────────────────────────────────────────────
var eval_node     = none
var eval_branches = none
var eval_block    = none
var call_fn       = none

# ── Value display ─────────────────────────────────────────────────────────────
var meta_repr = (v){
    v == none            :: "none",
    type(v) == "bool"    :: str(v),
    type(v) == "number": {
        v == floor(v) :: str(floor(v)),
        :: str(v)
    },
    :: str(v)
}

# ── Built-in functions available inside the meta-interpreter ──────────────────
var make_globals = (){
    var g = env_new(none),

    env_set(g, "print", {"tag": "builtin", "name": "print"}),
    env_set(g, "len",   {"tag": "builtin", "name": "len"}),
    env_set(g, "str",   {"tag": "builtin", "name": "str"}),
    env_set(g, "num",   {"tag": "builtin", "name": "num"}),
    env_set(g, "type",  {"tag": "builtin", "name": "type"}),
    env_set(g, "floor", {"tag": "builtin", "name": "floor"}),
    env_set(g, "push",  {"tag": "builtin", "name": "push"}),
    env_set(g, "pop",   {"tag": "builtin", "name": "pop"}),
    env_set(g, "list",  {"tag": "builtin", "name": "list"}),
    env_set(g, "map",   {"tag": "builtin", "name": "map"}),
    env_set(g, "keys",  {"tag": "builtin", "name": "keys"}),
    env_set(g, "has_key",  {"tag": "builtin", "name": "has_key"}),
    env_set(g, "ask",      {"tag": "builtin", "name": "ask"}),
    env_set(g, "args",     {"tag": "builtin", "name": "args"}),
    env_set(g, "dirof",    {"tag": "builtin", "name": "dirof"}),
    env_set(g, "_resolve_how",        {"tag": "builtin", "name": "_resolve_how"}),
    env_set(g, "del_key",    {"tag": "builtin", "name": "del_key"}),
    env_set(g, "values",     {"tag": "builtin", "name": "values"}),
    env_set(g, "_push_import_dir", {"tag": "builtin", "name": "_push_import_dir"}),
    env_set(g, "_dirname",        {"tag": "builtin", "name": "_dirname"}),
    env_set(g, "_basename",       {"tag": "builtin", "name": "_basename"}),
    env_set(g, "_add_search_dir", {"tag": "builtin", "name": "_add_search_dir"}),
    env_set(g, "_add_search_dir", {"tag": "builtin", "name": "_add_search_dir"}),
    env_set(g, "_basename",      {"tag": "builtin", "name": "_basename"}),
    env_set(g, "_dirname",       {"tag": "builtin", "name": "_dirname"}),
    # __dir is injected by how_meta.how after loading
    env_set(g, "_lex",     {"tag": "builtin", "name": "_meta_lex"}),
    env_set(g, "_host_call",  {"tag": "builtin", "name": "_host_call"}),
    env_set(g, "_meta_lex",   {"tag": "builtin", "name": "_meta_lex"}),
    env_set(g, "_meta_parse", {"tag": "builtin", "name": "_meta_parse"}),
    env_set(g, "_parse",   {"tag": "builtin", "name": "_meta_parse"}),
    env_set(g, "read",     {"tag": "builtin", "name": "read"}),
    env_set(g, "set_key",  {"tag": "builtin", "name": "set_key"}),
    env_set(g, "get_key",  {"tag": "builtin", "name": "get_key"}),
    env_set(g, "range",  {"tag": "builtin", "name": "range"}),
    env_set(g, "abs",    {"tag": "builtin", "name": "abs"}),
    env_set(g, "ceil",   {"tag": "builtin", "name": "ceil"}),
    env_set(g, "sqrt",   {"tag": "builtin", "name": "sqrt"}),
    env_set(g, "max",    {"tag": "builtin", "name": "max"}),
    env_set(g, "min",    {"tag": "builtin", "name": "min"}),
    env_set(g, "bool",   {"tag": "builtin", "name": "bool"}),
    env_set(g, "quit",   {"tag": "builtin", "name": "quit"}),
    env_set(g, "true",  true),
    env_set(g, "false", false),
    env_set(g, "none",  none),
    :: g
}

var call_builtin = (name, bargs){
    name == "print": {
        var i = 0, var parts = list(),
        var _i0=0, var _n0=len(bargs), (:)={ _i0>=_n0: break, push(parts, meta_repr(bargs(_i0))), _i0=_i0+1 },
        var s = "",
        var _i1=0, var _n1=len(parts), (:)={ _i1>=_n1: break, _i1>0: s=s+" ", s=s+parts(_i1), _i1=_i1+1 },
        print(s),
        :: ok_sig(none)
    },
    name == "len":     { :: ok_sig(len(bargs(0))) },
    name == "str":     { :: ok_sig(meta_repr(bargs(0))) },
    name == "num":     { :: ok_sig(num(str(bargs(0)))) },
    name == "type": {
        var tv = bargs(0),
        type(tv) == "map" and has_key(tv, "tag") and tv("tag") == "instance": {
            :: ok_sig("instance")
        },
        :: ok_sig(type(tv))
    },
    name == "floor":   { :: ok_sig(floor(bargs(0))) },
    name == "push":    { push(bargs(0), bargs(1)), :: ok_sig(bargs(0)) },
    name == "pop":     { :: ok_sig(pop(bargs(0))) },
    name == "list":    { :: ok_sig(list()) },
    name == "map":     { :: ok_sig(map()) },
    name == "keys":    { :: ok_sig(keys(bargs(0))) },
    name == "has_key": { :: ok_sig(has_key(bargs(0), bargs(1))) },
    name == "set_key": { set_key(bargs(0), bargs(1), bargs(2)), :: ok_sig(bargs(2)) },
    name == "get_key": { :: ok_sig(get_key(bargs(0), bargs(1))) },
    name == "ask":     { :: ok_sig(ask(bargs(0))) },
    name == "args":   { :: ok_sig(args()) },
    name == "dirof":         { :: ok_sig(dirof(bargs(0))) },
    name == "_resolve_how":        { :: ok_sig(_resolve_how(bargs(0))) },
    name == "del_key":  { del_key(bargs(0), bargs(1)), :: ok_sig(none) },
    name == "values":   { :: ok_sig(values(bargs(0))) },
    name == "_push_import_dir": { :: ok_sig(_push_import_dir(bargs(0))) },
    name == "_dirname":        { :: ok_sig(_dirname(bargs(0))) },
    name == "_basename":       { :: ok_sig(_basename(bargs(0))) },
    name == "_add_search_dir": { :: ok_sig(_add_search_dir(bargs(0))) },
    name == "_add_search_dir": { :: ok_sig(_add_search_dir(bargs(0))) },
    name == "_basename": { :: ok_sig(_basename(bargs(0))) },
    name == "_dirname":  { :: ok_sig(_dirname(bargs(0))) },
    name == "__get_meta_dir": { :: ok_sig(__get_meta_dir()) },
    name == "_lex":    { :: ok_sig(_lex(bargs(0))) },
    name == "_host_call":  { :: ok_sig(_host_call(bargs(0), bargs(1))) },
    name == "_meta_lex":   { :: ok_sig(_meta_lex(bargs(0))) },
    name == "_meta_parse": { :: ok_sig(_meta_parse(bargs(0))) },
    name == "_parse":  { :: ok_sig(_parse(bargs(0))) },
    name == "read":    { :: ok_sig(read(bargs(0))) },
    name == "range": {
        len(bargs) == 1: { :: ok_sig(range(bargs(0))) },
        len(bargs) == 2: { :: ok_sig(range(bargs(0), bargs(1))) },
        :: ok_sig(range(bargs(0), bargs(1), bargs(2)))
    },
    name == "abs":   { :: ok_sig(abs(bargs(0))) },
    name == "ceil":  { :: ok_sig(ceil(bargs(0))) },
    name == "sqrt":  { :: ok_sig(sqrt(bargs(0))) },
    name == "max":   { :: ok_sig(max(bargs(0))) },
    name == "min":   { :: ok_sig(min(bargs(0))) },
    name == "bool":  { :: ok_sig(bool(bargs(0))) },
    name == "quit":  { quit() },
    :: ok_sig(none)
}

# ── Augmented assignment helpers ──────────────────────────────────────────────
var apply_aug = (old, op, val){
    op == "+=" :: old + val,
    op == "-=" :: old - val,
    op == "*=" :: old * val,
    op == "/=" :: old / val,
    :: val
}

# ── Main evaluator ────────────────────────────────────────────────────────────
eval_node = (node, env){
    var tag = node("tag"),

    tag == "num"      :: ok_sig(node("v")),
    tag == "str"      :: ok_sig(node("v")),
    tag == "bool"     :: ok_sig(node("v")),
    tag == "none_lit" :: ok_sig(none),
    tag == "break_node" :: break_sig(),

    tag == "ident": {
        :: ok_sig(env_get(env, node("name")))
    },

    tag == "unary": {
        var r = eval_node(node("e"), env),
        r("sig") != "ok" :: r,
        node("op") == "-"   :: ok_sig(-r("val")),
        node("op") == "not" :: ok_sig(is_truthy(r("val")) == false),
        :: ok_sig(r("val"))
    },

    tag == "binop": {
        var op = node("op"),
        # Short-circuit
        op == "and": {
            var l = eval_node(node("l"), env),
            l("sig") != "ok" :: l,
            is_truthy(l("val")) == false :: ok_sig(l("val")),
            :: eval_node(node("r"), env)
        },
        op == "or": {
            var l = eval_node(node("l"), env),
            l("sig") != "ok" :: l,
            is_truthy(l("val")) :: ok_sig(l("val")),
            :: eval_node(node("r"), env)
        },
        var l = eval_node(node("l"), env),
        l("sig") != "ok" :: l,
        var r = eval_node(node("r"), env),
        r("sig") != "ok" :: r,
        var lv = l("val"), var rv = r("val"),
        op == "+"  :: ok_sig(lv + rv),
        op == "-"  :: ok_sig(lv - rv),
        op == "*"  :: ok_sig(lv * rv),
        op == "/"  :: ok_sig(lv / rv),
        op == "%"  :: ok_sig(lv % rv),
        op == "==" :: ok_sig(lv == rv),
        op == "!=" :: ok_sig(lv != rv),
        op == "<"  :: ok_sig(lv < rv),
        op == ">"  :: ok_sig(lv > rv),
        op == "<=" :: ok_sig(lv <= rv),
        op == ">=" :: ok_sig(lv >= rv),
        :: ok_sig(none)
    },

    tag == "assign": {
        var rv = eval_node(node("val"), env),
        rv("sig") != "ok" :: rv,
        var tgt = node("target"),
        tgt("tag") == "ident": {
            var op = node("op"),
            op == "=": {
                env_assign(env, tgt("name"), rv("val")),
                :: ok_sig(rv("val"))
            },
            var old = env_get(env, tgt("name")),
            var newv = apply_aug(old, op, rv("val")),
            env_assign(env, tgt("name"), newv),
            :: ok_sig(newv)
        },
        tgt("tag") == "dot": {
            var objr = eval_node(tgt("obj"), env),
            objr("sig") != "ok" :: objr,
            var da_obj = objr("val"),
            # Instance: write into its fields map
            type(da_obj) == "map" and has_key(da_obj, "tag") and
            da_obj("tag") == "instance": {
                set_key(da_obj("fields"), tgt("attr"), rv("val")),
                :: ok_sig(rv("val"))
            },
            type(da_obj) == "map": {
                set_key(da_obj, tgt("attr"), rv("val")),
                :: ok_sig(rv("val"))
            },
            :: ok_sig(none)
        },
        :: ok_sig(none)
    },

    tag == "dot": {
        var r = eval_node(node("obj"), env),
        r("sig") != "ok" :: r,
        var obj  = r("val"),
        var attr = node("attr"),
        # Instance — read from its fields map
        type(obj) == "map" and has_key(obj, "tag") and obj("tag") == "instance": {
            has_key(obj("fields"), attr) :: ok_sig(get_key(obj("fields"), attr)),
            :: ok_sig(none)
        },
        type(obj) == "map": {
            has_key(obj, attr) :: ok_sig(get_key(obj, attr)),
            :: ok_sig(none)
        },
        :: ok_sig(none)
    },

    tag == "slice": {
        var r = eval_node(node("col"), env),
        r("sig") != "ok" :: r,
        var col = r("val"),
        var start = none, var stop = none,
        node("start") != none: {
            var rs = eval_node(node("start"), env),
            rs("sig") != "ok" :: rs,
            start = rs("val")
        },
        node("stop") != none: {
            var re = eval_node(node("stop"), env),
            re("sig") != "ok" :: re,
            stop = re("val")
        },
        type(col) == "list": {
            var s = 0,
            start != none: s = floor(start),
            var e = len(col),
            stop != none: e = floor(stop),
            :: ok_sig(col(s:e))
        },
        type(col) == "string": {
            var s = 0,
            start != none: s = floor(start),
            var e = len(col),
            stop != none: e = floor(stop),
            :: ok_sig(col(s:e))
        },
        :: ok_sig(none)
    },

    tag == "call": {
        var rc = eval_node(node("callee"), env),
        rc("sig") != "ok" :: rc,
        var callee = rc("val"),
        # Evaluate args (use (:)= loop to avoid for_loop return signal polluting call result)
        var args = list(),
        var ai = 0,
        var arg_nodes = node("args"),
        var arg_ok = true,
        var n_args = len(arg_nodes),
        (:)={
            ai >= n_args: break,
            var ra = eval_node(arg_nodes(ai), env),
            ra("sig") != "ok": { arg_ok = false },
            ra("sig") == "ok": push(args, ra("val")),
            ai = ai + 1
        },
        # Call
        type(callee) == "map" and has_key(callee, "tag") and get_key(callee, "tag") == "builtin": {
            var bres2 = call_builtin(get_key(callee, "name"), args),
                bres2("sig") == "return": { :: bres2("val") },
                :: bres2
        },
        type(callee) == "map" and has_key(callee, "tag") and get_key(callee, "tag") == "closure": {
            :: call_fn(callee, args)
        },
        # Class instantiation
        type(callee) == "map" and has_key(callee, "tag") and get_key(callee, "tag") == "class": {
            :: instantiate_class(callee, args, env)
        },
        # Call on list/map → index
        type(callee) == "list": { :: ok_sig(callee(floor(args(0)))) },
        type(callee) == "map":  {
            has_key(callee, args(0)): { :: ok_sig(get_key(callee, args(0))) },
            :: ok_sig(none)
        },
        # HOST function (HowFunction object) — call via host dispatch
        type(callee) == "function": {
            :: ok_sig(_host_call(callee, args))
        },
        :: ok_sig(none)
    },

    tag == "func": {
        :: ok_sig({"tag": "closure", "params": node("params"),
                   "branches": node("branches"), "env": env,
                   "is_loop": node("is_loop")})
    },

    tag == "map_lit": {
        var items = node("items"),
        # Detect list vs map
        len(items) == 0: { :: ok_sig(map()) },
        items(0)("k") == none: {
            var lst = list(),
            var ii = 0,
            (0:len(items)) = ii{
                var rv2 = eval_node(items(ii)("v"), env),
                rv2("sig") == "ok": push(lst, rv2("val"))
            },
            :: ok_sig(lst)
        },
        var m = map(),
        var ii = 0,
        (0:len(items)) = ii{
            var rk2 = eval_node(items(ii)("k"), env),
            var rv2 = eval_node(items(ii)("v"), env),
            rk2("sig") == "ok" and rv2("sig") == "ok": {
                set_key(m, rk2("val"), rv2("val"))
            }
        },
        :: ok_sig(m)
    },

    tag == "how_stmt": {
        var mod_name_raw = node("name"),
        var alias = node("alias"),   # may be none
        # Split path: "samples/lru_cache" → add "samples" to search, bind as "lru_cache"
        var mod_name = mod_name_raw,
        type(_basename) == "builtin": {
            var dir_part = _dirname(mod_name_raw),
            var base = _basename(mod_name_raw),
            dir_part != "": { _add_search_dir(dir_part) },
            mod_name = base
        },
        var mod_path = _resolve_how(mod_name),
        var mod_src  = read(mod_path),
        # Resolve _lex and _parse from env so meta versions can override builtins
        var lex_fn   = env_get(env, "_lex"),
        var parse_fn = env_get(env, "_parse"),
        # Call them: call_fn handles both closures and builtins
        var lex_args   = list(),
        push(lex_args, mod_src),
        var r_lex      = call_fn(lex_fn, lex_args),
        r_lex("sig") != "ok" :: r_lex,
        var mod_tokens = r_lex("val"),
        var parse_args = list(),
        push(parse_args, mod_tokens),
        var r_parse    = call_fn(parse_fn, parse_args),
        r_parse("sig") != "ok" :: r_parse,
        var mod_ast    = r_parse("val"),
        # Run the module in a fresh env that also has _lex/_parse overrides
        var mod_g    = make_globals(),
        set_key(mod_g("vars"), "_lex",   lex_fn),
        set_key(mod_g("vars"), "_parse", parse_fn),
        var mod_env  = env_new(mod_g),
        eval_node(mod_ast, mod_env),
        # Expose all module vars as a map
        var mod_map  = map(),
        var mod_keys = keys(mod_env("vars")),
        var ki = 0,
        var nk = len(mod_keys),
        (:)={
            ki >= nk: break,
            set_key(mod_map, mod_keys(ki), get_key(mod_env("vars"), mod_keys(ki))),
            ki = ki + 1
        },
        # Use alias if provided, otherwise use mod_name
        var bind_as = mod_name,
        alias != none: { bind_as = alias },
        env_set(env, bind_as, mod_map),
        # Also bind each module var directly into the calling env
        var ki2 = 0,
        (:)={
            ki2 >= nk: break,
            var mvar_name = mod_keys(ki2),
            var mvar_val  = get_key(mod_map, mvar_name),
            env_set(env, mvar_name, mvar_val),
            ki2 = ki2 + 1
        },
        :: ok_sig(mod_map)
    },
    tag == "where_stmt": {
        # where "dir" — add directory to module search path
        _add_search_dir(node("path")),
        :: ok_sig(none)
    },
    tag == "var_decl": {
        var r = eval_node(node("val"), env),
        r("sig") != "ok" :: r,
        env_set(env, node("name"), r("val")),
        :: ok_sig(r("val"))
    },

    tag == "block": {
        :: eval_block(node("stmts"), env)
    },

    tag == "for_loop": {
        var start_r  = none,
        node("start") != none: start_r = eval_node(node("start"), env),
        var start_v  = 0,
        start_r != none and start_r("sig") == "ok": start_v = floor(start_r("val")),
        var stop_r   = eval_node(node("stop"), env),
        stop_r("sig") != "ok" :: stop_r,
        var stop_v   = floor(stop_r("val")),
        var iter_var = node("var"),
        var branches = node("branches"),
        var loop_i   = start_v,
        var loop_res = ok_sig(none),
        var for_done = false,
        (:)={
            for_done: break,
            loop_i >= stop_v: { for_done = true },
            loop_i < stop_v: {
                env_set(env, iter_var, loop_i),
                var bi = 0,
                var iter_done = false,
                (:)={
                    iter_done: break,
                    bi >= len(branches): { iter_done = true },
                    bi < len(branches): {
                        var b = branches(bi),
                        b("tag") == "var_decl": {
                            var r = eval_node(b("val"), env),
                            r("sig") == "ok": env_set(env, b("name"), r("val")),
                            bi = bi + 1
                        },
                        b("tag") == "branch": {
                            var cond = b("cond"),
                            var cond_ok = true,
                            cond != none: {
                                var rc = eval_node(cond, env),
                                rc("sig") != "ok": { loop_res = rc, for_done = true, iter_done = true, cond_ok = false },
                                rc("sig") == "ok" and is_truthy(rc("val")) == false: { cond_ok = false }
                            },
                            cond_ok and b("is_ret") == false: {
                                var rb = eval_node(b("body"), env),
                                rb("sig") == "break": { for_done = true, iter_done = true },
                                rb("sig") == "return": { loop_res = rb, for_done = true, iter_done = true },
                                rb("sig") == "ok": bi = bi + 1
                            },
                            cond_ok and b("is_ret"): {
                                # :: branch: evaluate each iteration; last value becomes result
                                var rb = eval_node(b("body"), env),
                                rb("sig") == "ok": loop_res = ok_sig(rb("val")),
                                rb("sig") == "return": { loop_res = rb, for_done = true, iter_done = true },
                                bi = bi + 1
                            },
                            cond_ok == false: { bi = bi + 1 }
                        },
                        b("tag") != "var_decl" and b("tag") != "branch": { bi = bi + 1 }
                    }
                },
                for_done == false: loop_i = loop_i + 1
            }
        },

        :: loop_res
    },

    tag == "class_def": {
        # Build a class object capturing params, branches, and current env
        :: ok_sig({"tag": "class", "params": node("params"),
                    "branches": node("branches"), "env": env})
    },

    tag == "prog": {
        # prog stmts are branches — use eval_branches so conditions work correctly
        :: eval_branches(node("stmts"), env)
    },

    :: ok_sig(none)
}

# ── Block evaluation ──────────────────────────────────────────────────────────
eval_block = (stmts, env){
    var child = env_new(env),
    var si = 0,
    var result = ok_sig(none),
    (0:len(stmts)) = si{
        result("sig") != "ok": break,
        var stmt = stmts(si),
        var stag = stmt("tag"),
        # var_decl and branch are dispatched normally through eval_node
        # branch nodes need special eval_branches treatment (single-branch list)
        stag == "branch": {
            var single = list(),
            push(single, stmt),
            var rb = eval_branches(single, child),
            rb("sig") != "ok": { result = rb }
        },
        stag != "branch": {
            var r = eval_node(stmt, child),
            r("sig") != "ok": { result = r }
        }
    },
    :: result
}

# ── Branch list evaluation ────────────────────────────────────────────────────
eval_branches = (branches, env){
    var bi = 0,
    var result = ok_sig(none),
    var done = false,
    (:)={
        done: break,
        bi >= len(branches): { done = true },
        bi < len(branches): {
            var b   = branches(bi),
            var tag = b("tag"),

            # var_decl inside branch list
            tag == "var_decl": {
                var r = eval_node(b("val"), env),
                r("sig") == "ok": {
                    env_set(env, b("name"), r("val")),
                    result = r    # track last declared value as result
                },
                bi = bi + 1
            },

            # branch node
            tag == "branch": {
                var cond = b("cond"),
                var cond_ok = true,
                cond != none: {
                    var rc = eval_node(cond, env),
                    rc("sig") != "ok": { result = rc, done = true, cond_ok = false },
                    rc("sig") == "ok" and is_truthy(rc("val")) == false: { cond_ok = false }
                },
                cond_ok: {
                    b("is_ret"): {
                        var rb = eval_node(b("body"), env),
                        rb("sig") == "break": { result = break_sig(), done = true },
                        rb("sig") != "break": {
                            result = ret_sig(rb("val")),
                            done   = true
                        }
                    },
                    b("is_ret") == false: {
                        var rb = eval_node(b("body"), env),
                        rb("sig") == "break": { result = break_sig(), done = true },
                        rb("sig") == "return": { result = rb, done = true },
                        rb("sig") == "ok": {
                            result = rb,    # keep last ok value as result
                            bi = bi + 1
                        }
                    }
                },
                cond_ok == false: { bi = bi + 1 }
            },

            tag != "var_decl" and tag != "branch": {
                # Evaluate non-branch statements (for_loop, call, assign, etc.) as side effects
                var r = eval_node(b, env),
                # for_loop and similar return via :: loop_res — treat as side-effect (ignore return signal)
                r("sig") == "break": { result = break_sig(), done = true },
                r("sig") == "return" or r("sig") == "ok": { bi = bi + 1 }
            }
        }
    },
    :: result
}

# ── Function call ─────────────────────────────────────────────────────────────
call_fn = (fn, args){
    # Dispatch builtins (e.g. {tag:"builtin", name:"_lex"})
    type(fn) == "map" and has_key(fn, "tag") and fn("tag") == "builtin": {
        var bres = call_builtin(fn("name"), args),
        # call_builtin uses :: which creates {sig:"return", val:ok_sig(...)};
        # unwrap the return layer so caller sees the ok_sig directly
        bres("sig") == "return": { :: bres("val") },
        :: bres
    },
    # Native host function (e.g. how_lexer.tokenise passed directly):
    # call it using _host_call which bridges to the C interpreter
    type(fn) == "function" or type(fn) == "builtin": {
        :: ok_sig(_host_call(fn, args))
    },
    fn("is_loop"): {
        # Unbounded loop
        var local = env_new(fn("env")),
        var loop_result = ok_sig(none),
        var loop_done   = false,
        (:)={
            loop_done: break,
            var r = eval_branches(fn("branches"), local),
            r("sig") == "return": { loop_result = ok_sig(r("val")), loop_done = true },
            r("sig") == "break":  { loop_result = ok_sig(none),     loop_done = true },
            r("sig") == "ok":     none   # keep looping
        },
        :: loop_result
    },
    # Normal function
    var local = env_new(fn("env")),
    var pi = 0,
    (0:len(fn("params"))) = pi{
        env_set(local, fn("params")(pi), args(pi))
    },
    var r = eval_branches(fn("branches"), local),
    r("sig") == "return" :: ok_sig(r("val")),
    :: ok_sig(none)
}

# ── Public entry point ────────────────────────────────────────────────────────
# ── Class instantiation ────────────────────────────────────────────────────────
var instantiate_class = (cls, args, outer_env){
    var params   = cls("params"),
    var branches = cls("branches"),
    var cls_env  = cls("env"),

    var init_env = env_new(cls_env),
    var pi = 0,
    (0:len(params)) = pi{
        env_set(init_env, params(pi), args(pi))
    },

    # Collect fields and run side-effects during init
    var fields = map(),
    var bi = 0,
    (0:len(branches)) = bi{
        var b = branches(bi),
        # var decl → local init variable
        b("tag") == "var_decl": {
            var r = eval_node(b("val"), init_env),
            r("sig") == "ok": env_set(init_env, b("name"), r("val"))
        },
        b("tag") == "branch": {
            var cond = b("cond"),
            # Named field:  ident_cond: expr  (is_ret=false, cond is identifier/string)
            cond != none and b("is_ret") == false: {
                var key = none,
                cond("tag") == "ident": { key = cond("name") },
                cond("tag") == "str":   { key = cond("v") },
                key != none: {
                    var rv = eval_node(b("body"), init_env),
                    rv("sig") == "ok": set_key(fields, key, rv("val"))
                },
                key == none: {
                    var rc = eval_node(cond, init_env),
                    rc("sig") == "ok" and is_truthy(rc("val")): eval_node(b("body"), init_env)
                }
            },
            # Unconditional side-effect (e.g. h.next = t)
            cond == none and b("is_ret") == false: {
                eval_node(b("body"), init_env)
            }
        }
    },

    # Build instance env whose vars dict IS fields
    # Closures that mutate "size", "store" etc. mutate the shared instance fields
    var inst_env = {"vars": fields, "parent": init_env},

    # Re-wrap method closures to close over inst_env
    var fk = keys(fields),
    var ki = 0,
    (0:len(fk)) = ki{
        var k = fk(ki),
        var v = get_key(fields, k),
        type(v) == "map" and has_key(v, "tag") and v("tag") == "closure": {
            set_key(fields, k, {"tag": "closure", "params": v("params"),
                                 "branches": v("branches"), "env": inst_env,
                                 "is_loop": v("is_loop")})
        }
    },

    :: ok_sig({"tag": "instance", "fields": fields, "inst_env": inst_env})
}

var meta_eval = (ast){
    var g = make_globals(),
    :: eval_node(ast, g)
}

# meta_eval_ex: like meta_eval but uses caller-supplied lex/parse functions.
# This is used by how_meta.how when running under the C interpreter (which
# lacks the Python-specific _meta_lex/_meta_parse builtins).
var meta_eval_ex = (ast, lex_fn, parse_fn){
    var g = make_globals(),
    # Override _lex/_parse with the real module functions
    env_set(g, "_lex",   lex_fn),
    env_set(g, "_parse", parse_fn),
    env_set(g, "_meta_lex",   lex_fn),
    env_set(g, "_meta_parse", parse_fn),
    :: eval_node(ast, g)
}
