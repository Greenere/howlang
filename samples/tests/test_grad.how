# test_grad.how — grad() is opt-in via set_grad(...)

var TOTAL  = 0
var PASSED = 0

var ok = (name){
    TOTAL += 1,
    PASSED += 1,
    print("PASS: " + name)
}

var bad = (name, got, expected){
    TOTAL += 1,
    print("FAIL: " + name + " | got=" + str(got) + " expected=" + str(expected))
}

var assert_eq = (name, got, expected){
    got == expected : ok(name),
    got != expected : bad(name, got, expected)
}

var assert_close = (name, got, expected){
    var diff = got - expected,
    diff < 0 : diff = -diff,
    diff < 0.0001 : ok(name),
    diff >= 0.0001 : bad(name, got, expected)
}

print("=== grad() opt-in semantics ===")

var sq = (x){ :: x * x }
assert_eq("plain function has no grad by default", grad(sq), none)

var relu = (x){
    x > 0 :: x,
    :: 0
}
assert_eq("branching function has no grad by default", grad(relu), none)

assert_eq("builtins also report no grad by default", grad(sqrt), none)

set_grad(sq, (x, g){ :: {} })
var d_sq = grad(sq)
assert_eq("set_grad makes grad visible", d_sq == none, false)
assert_close("empty override opts in tape-backed grad at x=3", d_sq(3.0)("x"), 6.0)
assert_close("empty override opts in tape-backed grad at x=-2", d_sq(-2.0)("x"), -4.0)

set_grad(relu, (x, g){
    x > 0 :: g,
    :: 0
})
var d_relu = grad(relu)
assert_close("custom grad positive branch", d_relu(2.0)("x"), 1.0)
assert_close("custom grad negative branch", d_relu(-2.0)("x"), 0.0)

var mixed = (x, y){ :: x * x + 3 * y }
set_grad(mixed, (x, y, g){
    :: {"y": 10 * g}
})
var d_mixed = grad(mixed)(4.0, 2.0)
assert_close("partial override keeps tape gradient for x", d_mixed("x"), 8.0)
assert_close("partial override replaces y gradient", d_mixed("y"), 10.0)

var w = 5.0
var loss = (){ :: (w - 2) * (w - 2) }
assert_eq("zero-arg closures are also gated by set_grad", grad(loss), none)
set_grad(loss, (g){ :: {} })
var d_loss = grad(loss)()
assert_close("closure grad after opt-in", d_loss("w"), 6.0)

set_grad(sq, (x, g){ :: 3 * x * g })
assert_close("set_grad can replace an existing rule", grad(sq)(2.0)("x"), 6.0)

assert_eq("grad wrappers do not auto-expose higher-order grads", grad(grad(sq)), none)

print("")
print("═════════════════════════════════════════════════")
print("  " + str(PASSED) + " passed   " + str(TOTAL - PASSED) + " failed")
print("═════════════════════════════════════════════════")
