# test_grad.how — comprehensive tests for grad() automatic differentiation
#
# Sections:
#   1. Scalar forward-mode  (single numeric argument)
#   2. Higher-order derivatives
#   3. Arithmetic rules     (each operator in isolation)
#   4. Built-in functions   (sqrt, abs, floor, ceil)
#   5. Multivariate partial derivatives
#   6. Branching functions  (relu, sign, step)
#   7. Non-differentiable / non-numeric returns
#   8. Custom grad blocks
#   9. Closure reverse-mode (zero-arg, returns gradient map)
#  10. grad() on class fields (integration)
#  11. Gradient-based optimisation  (find minimum via gradient descent)

var TOTAL  = 0
var PASSED = 0

var line = (){ print("────────────────────────────────────────────────────────") }

var ok = (name){
    TOTAL  += 1,
    PASSED += 1,
    print("PASS: " + name)
}

var bad = (name, got, expected){
    TOTAL += 1,
    print("FAIL: " + name + " | got=" + str(got) + " expected=" + str(expected))
}

# Numeric equality with tolerance 1e-4
var assert_close = (name, got, expected){
    var diff = got - expected,
    diff < 0: diff = diff * -1,
    diff < 0.0001: ok(name),
    diff >= 0.0001: bad(name, got, expected)
}

# Exact equality (for none, bool, integer results)
var assert_eq = (name, got, expected){
    got == expected: ok(name),
    got != expected: bad(name, got, expected)
}


# ── Section 1: Scalar forward-mode ───────────────────────────────────────────
print("=== 1. Scalar forward-mode ===")
line()

var sq  = (x){ :: x * x }
var lin = (x){ :: 3 * x + 5 }
var inv = (x){ :: 1 / x }
var poly = (x){ :: x * x * x - 2 * x * x + x - 7 }

assert_close("d(x^2)/dx at x=0",     grad(sq)(0.0),   0.0)
assert_close("d(x^2)/dx at x=3",     grad(sq)(3.0),   6.0)
assert_close("d(x^2)/dx at x=-2",    grad(sq)(-2.0), -4.0)
assert_close("d(x^2)/dx at x=0.5",   grad(sq)(0.5),   1.0)

assert_close("d(3x+5)/dx at x=0",    grad(lin)(0.0),  3.0)
assert_close("d(3x+5)/dx is const",  grad(lin)(99.0), 3.0)

assert_close("d(1/x)/dx at x=2",     grad(inv)(2.0),  -0.25)
assert_close("d(1/x)/dx at x=4",     grad(inv)(4.0),  -0.0625)

# d/dx [x^3 - 2x^2 + x - 7] = 3x^2 - 4x + 1
assert_close("d(poly)/dx at x=0",    grad(poly)(0.0),  1.0)
assert_close("d(poly)/dx at x=1",    grad(poly)(1.0),  0.0)
assert_close("d(poly)/dx at x=3",    grad(poly)(3.0),  16.0)


# ── Section 2: Higher-order derivatives ──────────────────────────────────────
print("=== 2. Higher-order derivatives ===")
line()

# d^2/dx^2 [x^2] = 2
assert_close("d^2(x^2)/dx^2 at x=0",   grad(grad(sq))(0.0),   2.0)
assert_close("d^2(x^2)/dx^2 at x=5",   grad(grad(sq))(5.0),   2.0)
assert_close("d^2(x^2)/dx^2 at x=-3",  grad(grad(sq))(-3.0),  2.0)

# d^3/dx^3 [x^2] = 0
assert_close("d^3(x^2)/dx^3",          grad(grad(grad(sq)))(1.0), 0.0)

# d/dx [x^3] = 3x^2 ;  d^2/dx^2 = 6x
var cube = (x){ :: x * x * x }
assert_close("d(x^3)/dx at x=2",       grad(cube)(2.0),       12.0)
assert_close("d^2(x^3)/dx^2 at x=2",   grad(grad(cube))(2.0), 12.0)
assert_close("d^3(x^3)/dx^3",          grad(grad(grad(cube)))(1.0), 6.0)

# d^4/dx^4 [x^3] = 0
assert_close("d^4(x^3)/dx^4",          grad(grad(grad(grad(cube))))(1.0), 0.0)


# ── Section 3: Arithmetic rules ───────────────────────────────────────────────
print("=== 3. Arithmetic rules ===")
line()

# Addition: d/dx [x + c] = 1
var f_add = (x){ :: x + 10 }
assert_close("d(x+10)/dx",    grad(f_add)(5.0),  1.0)

# Subtraction: d/dx [x - c] = 1 ; d/dx [c - x] = -1
var f_sub1 = (x){ :: x - 3 }
var f_sub2 = (x){ :: 7 - x }
assert_close("d(x-3)/dx",     grad(f_sub1)(5.0),  1.0)
assert_close("d(7-x)/dx",     grad(f_sub2)(5.0), -1.0)

# Multiplication product rule: d/dx [x*x] = 2x
assert_close("product rule x*x at 4",  grad(sq)(4.0), 8.0)

# Division quotient rule: d/dx [1/x] = -1/x^2
assert_close("quotient rule at x=2",   grad(inv)(2.0), -0.25)
assert_close("quotient rule at x=5",   grad(inv)(5.0), -0.04)

# Unary negation: d/dx [-x^2] = -2x
var f_neg = (x){ :: -(x * x) }
assert_close("d(-x^2)/dx at x=3",  grad(f_neg)(3.0), -6.0)
assert_close("d(-x^2)/dx at x=-1", grad(f_neg)(-1.0), 2.0)

# Chain rule: d/dx [(x^2)^2] = 4x^3  — encoded as x*x*x*x
var f_chain = (x){ :: x * x * x * x }
assert_close("d(x^4)/dx at x=2",   grad(f_chain)(2.0), 32.0)
assert_close("d(x^4)/dx at x=-1",  grad(f_chain)(-1.0), -4.0)


# ── Section 4: Built-in functions ─────────────────────────────────────────────
print("=== 4. Built-in functions ===")
line()

# sqrt: d/dx [sqrt(x)] = 1/(2*sqrt(x))
var f_sqrt = (x){ :: sqrt(x) }
assert_close("d(sqrt)/dx at x=1",   grad(f_sqrt)(1.0),  0.5)
assert_close("d(sqrt)/dx at x=4",   grad(f_sqrt)(4.0),  0.25)
assert_close("d(sqrt)/dx at x=9",   grad(f_sqrt)(9.0),  0.16667)
assert_close("d(sqrt)/dx at x=0.25",grad(f_sqrt)(0.25), 1.0)

# sqrt chain rule: d/dx [sqrt(x^2)] = x/|x| = sign(x)  — only tested at x>0
var f_sqrt_chain = (x){ :: sqrt(x * x) }
assert_close("d(sqrt(x^2))/dx at x=3",  grad(f_sqrt_chain)(3.0),  1.0)

# abs: d/dx [|x|] = sign(x)
var f_abs = (x){ :: abs(x) }
assert_close("d(abs)/dx at x=3",   grad(f_abs)(3.0),   1.0)
assert_close("d(abs)/dx at x=-4",  grad(f_abs)(-4.0), -1.0)

# floor/ceil: derivative is 0 almost everywhere
var f_floor = (x){ :: floor(x) + x }   # derivative = 0 + 1 = 1
var f_ceil  = (x){ :: ceil(x)  + x }   # derivative = 0 + 1 = 1
assert_close("d(floor(x)+x)/dx",  grad(f_floor)(2.7), 1.0)
assert_close("d(ceil(x)+x)/dx",   grad(f_ceil)(2.3),  1.0)

# Combined: d/dx [sqrt(abs(x))] = sign(x) / (2*sqrt(|x|))
var f_combined = (x){ :: sqrt(abs(x)) }
assert_close("d(sqrt(abs(x)))/dx at x=4",  grad(f_combined)(4.0),   0.25)
assert_close("d(sqrt(abs(x)))/dx at x=-4", grad(f_combined)(-4.0), -0.25)


# ── Section 5: Multivariate partial derivatives ───────────────────────────────
print("=== 5. Multivariate partial derivatives ===")
line()

# f(x,y) = x^2 + xy   →  ∂f/∂x = 2x+y,  ∂f/∂y = x
var fxy = (x, y){ :: x * x + x * y }
var dfxy = grad(fxy)
var g23 = dfxy(2.0, 3.0)
assert_close("∂(x^2+xy)/∂x at (2,3)", g23(0), 7.0)
assert_close("∂(x^2+xy)/∂y at (2,3)", g23(1), 2.0)

# f(x,y) = x*y   →  ∂f/∂x = y,  ∂f/∂y = x
var fmul = (x, y){ :: x * y }
var g_mul = grad(fmul)(3.0, 5.0)
assert_close("∂(x*y)/∂x at (3,5)", g_mul(0), 5.0)
assert_close("∂(x*y)/∂y at (3,5)", g_mul(1), 3.0)

# f(x,y,z) = x^2 + y^2 + z^2  →  gradients are (2x, 2y, 2z)
var f3 = (x, y, z){ :: x*x + y*y + z*z }
var g3 = grad(f3)(1.0, 2.0, 3.0)
assert_close("∂(x^2+y^2+z^2)/∂x", g3(0), 2.0)
assert_close("∂(x^2+y^2+z^2)/∂y", g3(1), 4.0)
assert_close("∂(x^2+y^2+z^2)/∂z", g3(2), 6.0)

# Cross terms: f(x,y) = x^2*y  →  ∂f/∂x = 2xy,  ∂f/∂y = x^2
var f_cross = (x, y){ :: x * x * y }
var g_cross = grad(f_cross)(3.0, 4.0)
assert_close("∂(x^2*y)/∂x at (3,4)", g_cross(0), 24.0)
assert_close("∂(x^2*y)/∂y at (3,4)", g_cross(1),  9.0)


# ── Section 6: Branching functions ────────────────────────────────────────────
print("=== 6. Branching functions ===")
line()

# relu (forward-mode via :: branch returning dual)
var relu_auto = (x){ x > 0 :: x, :: 0 } grad (x, g){ x > 0 :: g, :: 0 }
assert_close("grad relu at x=3",   grad(relu_auto)(3.0),  1.0)
assert_close("grad relu at x=0.1", grad(relu_auto)(0.1),  1.0)
assert_close("grad relu at x=-1",  grad(relu_auto)(-1.0), 0.0)
assert_close("grad relu at x=-10", grad(relu_auto)(-10.0),0.0)

# leaky relu: slope 0.01 for x<0
var leaky = (x){
    x > 0 :: x,
    :: 0.01 * x
} grad (x, g){
    x > 0 :: g,
    :: 0.01 * g
}
assert_close("grad leaky_relu at x=2",   grad(leaky)(2.0),   1.0)
assert_close("grad leaky_relu at x=-2",  grad(leaky)(-2.0),  0.01)

# max(x, c) — piecewise: slope 1 for x>c, 0 otherwise
var f_max = (x){ x > 2 :: x, :: 2 }  grad (x, g){ x > 2 :: g, :: 0 }
assert_close("grad max(x,2) at x=5",  grad(f_max)(5.0), 1.0)
assert_close("grad max(x,2) at x=1",  grad(f_max)(1.0), 0.0)

# Branching combined with arithmetic
var f_branch_arith = (x){
    x >= 0 :: x * x,
    :: -(x * x)
}
# Both branches have derivative 2x or -2x based on sign;
# at x=3: branch taken is x>=0, so derivative = 2*3 = 6
# at x=-2: branch taken is x<0, so f = -(x*x), derivative = -2x = 4
assert_close("grad piecewise x^2 at x=3",  grad(f_branch_arith)(3.0),  6.0)
assert_close("grad piecewise x^2 at x=-2", grad(f_branch_arith)(-2.0), 4.0)


# ── Section 7: Non-differentiable / non-numeric returns ───────────────────────
print("=== 7. Non-differentiable / non-numeric returns ===")
line()

# Function returning string → none
var f_str = (x){ x > 0 :: "pos", :: "neg" }
assert_eq("grad of string-returning fn", grad(f_str)(1.0), none)

# Function returning bool → none
var f_bool = (x){ :: x > 0 }
assert_eq("grad of bool-returning fn",   grad(f_bool)(1.0), none)

# Function returning none → none
var f_none = (x){ :: none }
assert_eq("grad of none-returning fn",   grad(f_none)(1.0), none)


# ── Section 8: Custom grad blocks ─────────────────────────────────────────────
print("=== 8. Custom grad blocks ===")
line()

# abs via custom block
var abs_c = (x){ x >= 0 :: x, :: -x } grad (x, g){ x >= 0 :: g, :: -g }
assert_close("custom abs grad at x=5",   grad(abs_c)(5.0),   1.0)
assert_close("custom abs grad at x=-3",  grad(abs_c)(-3.0), -1.0)

# Custom block composes with outer arithmetic
# d/dx [abs_c(x) * 2] — chain rule through the custom block
var f_abs2 = (x){ :: abs_c(x) * 2 }
assert_close("d(abs_c(x)*2)/dx at x=4",  grad(f_abs2)(4.0),   2.0)
assert_close("d(abs_c(x)*2)/dx at x=-4", grad(f_abs2)(-4.0), -2.0)

# Custom block: clamp(x, lo, hi)
var clamp = (x){
    x < 0 :: 0,
    x > 1 :: 1,
    :: x
} grad (x, g){
    x < 0 :: 0,
    x > 1 :: 0,
    :: g
}
assert_close("grad clamp at x=-1 (flat)", grad(clamp)(-1.0), 0.0)
assert_close("grad clamp at x=0.5 (lin)", grad(clamp)(0.5),  1.0)
assert_close("grad clamp at x=2  (flat)", grad(clamp)(2.0),  0.0)

# Custom block with scale: f(x) = x^2 grad block returns 2x*g
var sq_custom = (x){ :: x * x } grad (x, g){ :: 2 * x * g }
assert_close("custom sq grad at x=3",  grad(sq_custom)(3.0),  6.0)
assert_close("custom sq grad at x=-2", grad(sq_custom)(-2.0), -4.0)

# Higher-order through custom block: grad(grad(sq_custom)) should be 2
assert_close("grad^2 custom sq",       grad(grad(sq_custom))(5.0), 2.0)


# ── Section 9: Closure reverse-mode ──────────────────────────────────────────
print("=== 9. Closure reverse-mode (zero-arg) ===")
line()

# f = a^2 + b   →   ∂f/∂a = 2a,  ∂f/∂b = 1
var p = 3.0
var q = 2.0
var loss1 = (){ :: p * p + q }
var g1 = grad(loss1)()
assert_close("reverse ∂(p^2+q)/∂p", g1("p"), 6.0)
assert_close("reverse ∂(p^2+q)/∂q", g1("q"), 1.0)

# f = a * b   →   ∂f/∂a = b,  ∂f/∂b = a
var ca = 4.0
var cb = 5.0
var loss2 = (){ :: ca * cb }
var g2 = grad(loss2)()
assert_close("reverse ∂(a*b)/∂a", g2("ca"), 5.0)
assert_close("reverse ∂(a*b)/∂b", g2("cb"), 4.0)

# f = a^2 + b^2 + c^2  →  all partials are 2*var
var ra = 1.0
var rb = 2.0
var rc = 3.0
var loss3 = (){ :: ra*ra + rb*rb + rc*rc }
var g3_rev = grad(loss3)()
assert_close("reverse ∂(a^2+b^2+c^2)/∂a", g3_rev("ra"), 2.0)
assert_close("reverse ∂(a^2+b^2+c^2)/∂b", g3_rev("rb"), 4.0)
assert_close("reverse ∂(a^2+b^2+c^2)/∂c", g3_rev("rc"), 6.0)

# f = (a - b)^2  →  ∂f/∂a = 2(a-b),  ∂f/∂b = -2(a-b)
var ea = 5.0
var eb = 3.0
var loss4 = (){ var d = ea - eb, :: d * d }
var g4 = grad(loss4)()
assert_close("reverse ∂(a-b)^2/∂a",  g4("ea"),  4.0)
assert_close("reverse ∂(a-b)^2/∂b",  g4("eb"), -4.0)

# Closure does not mutate the original variables
assert_close("closure vars unchanged after grad: p", p, 3.0)
assert_close("closure vars unchanged after grad: q", q, 2.0)
assert_close("closure vars unchanged after grad: ca", ca, 4.0)


# ── Section 10: grad on class fields ─────────────────────────────────────────
print("=== 10. grad on class fields ===")
line()

var act_fn = (x){ x > 0 :: x, :: 0 } grad (x, g){ x > 0 :: g, :: 0 }

var Neuron = [w0, w1, b, act]{
    w0: w0, w1: w1, b: b, act: act,
    d_act: grad(act),
    forward: (x0, x1){ :: act(w0 * x0 + w1 * x1 + b) },
    d_input: (x0, x1){
        var z = w0 * x0 + w1 * x1 + b,
        :: d_act(z)
    }
}

var n = Neuron[2.0, 3.0, 1.0, act_fn]

# z = 2*1 + 3*2 + 1 = 9 > 0, so act(9)=9, d_act(9)=1
assert_close("neuron forward",  n.forward(1.0, 2.0),  9.0)
assert_close("neuron d_act",    n.d_input(1.0, 2.0),  1.0)

# z = 2*0 + 3*0 - 2 = -2 < 0, so act(-2)=0, d_act(-2)=0
var n2 = Neuron[2.0, 3.0, -2.0, act_fn]
assert_close("neuron forward (dead)", n2.forward(0.0, 0.0), 0.0)
assert_close("neuron d_act   (dead)", n2.d_input(0.0, 0.0), 0.0)


# ── Section 11: Gradient-based optimisation ───────────────────────────────────
print("=== 11. Gradient-based optimisation ===")
line()

# Minimise f(x) = (x - 3)^2  via gradient descent from x=0
# Minimum at x=3; gradient = 2*(x-3)
var target = 3.0
var x_opt = 0.0
var f_opt = (x){ :: (x - target) * (x - target) }
var lr_opt = 0.1

(step=0:100){
    x_opt = x_opt - lr_opt * grad(f_opt)(x_opt)
}()
assert_close("GD: minimise (x-3)^2, converges to 3", x_opt, 3.0)

# Minimise f(x) = x^4 - 4*x^2  →  local minima at ±sqrt(2) ≈ ±1.414
# Starting at x=1.5 → should converge to +sqrt(2)
var x2 = 1.5
var f_quartic = (x){ :: x*x*x*x - 4*x*x }
(step=0:200){
    x2 = x2 - 0.01 * grad(f_quartic)(x2)
}()
assert_close("GD: local min of x^4-4x^2", x2, 1.41421)

# Closure reverse-mode gradient descent:
# minimise L = (w - 2)^2 by updating w using grad(loss)()
var w = 0.0
(step=0:50){
    var gl = grad((){ :: (w - 2) * (w - 2) })(),
    w = w - 0.2 * gl("w")
}()
assert_close("GD via closure reverse-mode", w, 2.0)


# ── Final report ──────────────────────────────────────────────────────────────
line()
print("FINAL: " + str(PASSED) + "/" + str(TOTAL) + " passed")
