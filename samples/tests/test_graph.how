# ─────────────────────────────────────────────────────────────────────────────
# graph_test.how  —  Tests for graph.how
# Run as:  cat graph.how graph_test.how | python howlang.py -e "$(cat ...)"
# Or simply source graph.how first via: how graph
# ─────────────────────────────────────────────────────────────────────────────

how graph

var passed = 0
var failed = 0

var assert_eq = (label, got, expected){
    got == expected: {
        print("  PASS  " + label),
        passed = passed + 1
    },
    got != expected: {
        print("  FAIL  " + label + "  →  got: " + str(got) + "  expected: " + str(expected)),
        failed = failed + 1
    }
}
var assert_none  = (label, val){ assert_eq(label, val, none)  }
var assert_true  = (label, val){ assert_eq(label, val, true)  }
var assert_false = (label, val){ assert_eq(label, val, false) }


# ── Helper: print a path result ───────────────────────────────────────────────
var show_path = (label, result){
    result == none: {
        print("  " + label + ": no path")
    },
    result != none: {
        var p = result.path,
        var s = p(0),
        var i = 1,
        (:)={
            i >= len(p): break,
            s = s + " → " + p(i),
            i = i + 1
        },
        print("  " + label + ": " + s + "  (dist=" + str(result.dist) + ")")
    }
}


# ═════════════════════════════════════════════════════════════════════════════
print("─── Graph construction ──────────────────────────────────────────────────")

var g1 = graph.graph[]
g1.add_node("A")
g1.add_node("B")
g1.add_node("C")

assert_true ("has node A",          g1.has_node("A"))
assert_true ("has node B",          g1.has_node("B"))
assert_false("does not have node Z",g1.has_node("Z"))
assert_eq   ("node count",          len(g1.node_list()), 3)

g1.add_edge("A", "B", 4)
g1.add_edge("A", "C", 2)
g1.add_edge("B", "C", 1)

assert_eq("A has 2 neighbors",      len(g1.neighbors("A")), 2)
assert_eq("B has 1 neighbor",       len(g1.neighbors("B")), 1)
assert_eq("C has 0 neighbors",      len(g1.neighbors("C")), 0)

# add_edge auto-creates nodes
g1.add_edge("C", "D", 7)
assert_true("D auto-created",       g1.has_node("D"))


# ═════════════════════════════════════════════════════════════════════════════
print("─── Shortest path: simple 4-node directed graph ─────────────────────────")
#
#   A --4--> B
#   A --2--> C
#   B --1--> C
#   C --3--> D
#   B --5--> D
#
# Shortest A→D: A→C→D = 5  (not A→B→D = 9)

var g2 = graph.graph[]
g2.add_edge("A", "B", 4)
g2.add_edge("A", "C", 2)
g2.add_edge("B", "C", 1)
g2.add_edge("C", "D", 3)
g2.add_edge("B", "D", 5)

var r1 = graph.shortest_path(g2, "A", "D")
show_path("A→D", r1)
assert_eq("A→D distance",   r1.dist, 5)
assert_eq("A→D path len",   len(r1.path), 3)
assert_eq("A→D path[0]",    r1.path(0), "A")
assert_eq("A→D path[1]",    r1.path(1), "C")
assert_eq("A→D path[2]",    r1.path(2), "D")

var r2 = graph.shortest_path(g2, "A", "B")
show_path("A→B", r2)
assert_eq("A→B distance",   r2.dist, 4)
assert_eq("A→B path len",   len(r2.path), 2)

var r3 = graph.shortest_path(g2, "A", "C")
show_path("A→C", r3)
assert_eq("A→C distance",   r3.dist, 2)

# Same-node path
var r4 = graph.shortest_path(g2, "A", "A")
show_path("A→A", r4)
assert_eq("A→A distance",   r4.dist, 0)
assert_eq("A→A path len",   len(r4.path), 1)


# ═════════════════════════════════════════════════════════════════════════════
print("─── No path exists ──────────────────────────────────────────────────────")

var r5 = graph.shortest_path(g2, "D", "A")   # directed: no way back
show_path("D→A", r5)
assert_none("D→A returns none", r5)

var r6 = graph.shortest_path(g2, "A", "Z")   # Z doesn't exist
show_path("A→Z", r6)
assert_none("missing node returns none", r6)


# ═════════════════════════════════════════════════════════════════════════════
print("─── Undirected graph (add edges both ways) ───────────────────────────────")
#
#   1 --7-- 2
#   1 --9-- 3
#   1 --14- 6
#   2 --10- 3
#   2 --15- 4
#   3 --11- 4
#   3 --2-- 6
#   4 --6-- 5
#   5 --9-- 6
#
# Classic Dijkstra demo graph. Shortest 1→5: 1→3→6→5 = 20

var g3 = graph.graph[]
var add_undirected = (from_n, to_n, w){
    g3.add_edge(from_n, to_n, w),
    g3.add_edge(to_n, from_n, w)
}
add_undirected("1","2",7)
add_undirected("1","3",9)
add_undirected("1","6",14)
add_undirected("2","3",10)
add_undirected("2","4",15)
add_undirected("3","4",11)
add_undirected("3","6",2)
add_undirected("4","5",6)
add_undirected("5","6",9)

var r7 = graph.shortest_path(g3, "1", "5")
show_path("1→5", r7)
assert_eq("1→5 distance",   r7.dist, 20)
assert_eq("1→5 starts at 1", r7.path(0), "1")
assert_eq("1→5 ends at 5",   r7.path(len(r7.path)-1), "5")

var r8 = graph.shortest_path(g3, "1", "4")
show_path("1→4", r8)
assert_eq("1→4 distance",   r8.dist, 20)

var r9 = graph.shortest_path(g3, "3", "6")
show_path("3→6", r9)
assert_eq("3→6 distance",   r9.dist, 2)


# ═════════════════════════════════════════════════════════════════════════════
print("─── Single-node graph ───────────────────────────────────────────────────")

var g4 = graph.graph[]
g4.add_node("X")
var r10 = graph.shortest_path(g4, "X", "X")
assert_eq("single node X→X dist", r10.dist, 0)


# ═════════════════════════════════════════════════════════════════════════════
print("─── Priority queue (min-heap) directly ──────────────────────────────────")

var q = graph.pq[]
q.push_pq(5, "five")
q.push_pq(1, "one")
q.push_pq(3, "three")
q.push_pq(2, "two")
q.push_pq(4, "four")

assert_eq("pq pop 1", q.pop_pq().val, "one")
assert_eq("pq pop 2", q.pop_pq().val, "two")
assert_eq("pq pop 3", q.pop_pq().val, "three")
assert_eq("pq pop 4", q.pop_pq().val, "four")
assert_eq("pq pop 5", q.pop_pq().val, "five")
assert_none("pq empty returns none", q.pop_pq())


# ═════════════════════════════════════════════════════════════════════════════
print("")
print("═════════════════════════════════════════════════")
print("  " + str(passed) + " passed   " + str(failed) + " failed")
print("═════════════════════════════════════════════════")
