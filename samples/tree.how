var node = [val, left, right, leaf] {
    val:val,
    left:left,
    right:right,
    leaf:leaf
}

var root = node[0,
                node[1, none, none, true],
                node[2, none, none, true], 
                false]

var traverse = (node){
    node == none: {},
    node.leaf: {node.val},
    ::traverse(node.left) + {node.val} + traverse(node.right)
}

var res = traverse(root)

print(res)
