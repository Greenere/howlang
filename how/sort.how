var merge = (nums1, nums2){
    len(nums1) == 0: nums2,
    len(nums2) == 0: nums1,
    nums1[0] <= nums2[0]: [nums1[0]] + merge(nums1[1:],nums2),
    :: [nums2[0]] + merge(nums2[1:],nums1)
}

var sort = (nums){
    len(nums) == 1: [nums[0]],
    len(nums) == 2: (nums){
        nums[0] <= nums[1]: nums,
        :: [nums[1], nums[0]]
    }(nums)
    :: merge(sort(nums[0:len(nums)/2]), sort(nums[len(nums)/2:len(nums)]))
}

var nums = {1,2,3,4,5}

print(sort(nums))