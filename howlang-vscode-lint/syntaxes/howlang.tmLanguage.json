{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Howlang",
  "scopeName": "source.howlang",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#constants" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.howlang",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.howlang",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.howlang", "match": "\\\\[ntr\\\"']" }
          ]
        },
        {
          "name": "string.quoted.single.howlang",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.howlang", "match": "\\\\[ntr\\\"']" }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.howlang",
          "match": "\\b(?:var|how|where|as|break|continue|catch)\\b"
        },
        {
          "name": "keyword.operator.logical.howlang",
          "match": "\\b(?:and|or|not)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.howlang",
          "match": "\\b(?:true|false|none)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.howlang",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.howlang",
          "match": "!!|::|\\+=|-=|\\*=|/=|%=|==|!=|<=|>=|&&|\\|\\||[+\\-*/%=<>:^.]"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.call.howlang",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()"
        },
        {
          "name": "support.class.instance.howlang",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\[)"
        }
      ]
    }
  }
}
